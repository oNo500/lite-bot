{
  "name": "boilerplate",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev -F !web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "up:all": "taze -r"
  },
  "devDependencies": {
    "@infra-x/code-quality": "^0.6.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "taze": "^19.10.0",
    "turbo": "^2.8.17"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "antd",
        "openapi-fetch",
        "storybook"
      ]
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "bcrypt",
      "better-sqlite3",
      "@swc/core",
      "esbuild"
    ]
  }
}
